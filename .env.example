# --- Third-party Instagram scraper API ---
# This project does NOT scrape Instagram directly (unreliable + against ToS).
# Instead it calls a managed scraper API. The example below is written against
# a RapidAPI-style provider, but any provider works as long as you adapt the
# request/response mapping in app/services/instagram_scraper.py.

# Your provider API key (e.g. RapidAPI key)
SCRAPER_API_KEY=your_api_key_here

# The provider host header (RapidAPI requires this; leave blank if not needed)
SCRAPER_API_HOST=instagram-scraper-api2.p.rapidapi.com

# Full endpoint the request is sent to
SCRAPER_API_URL=https://instagram-scraper-api2.p.rapidapi.com/v1/post_info

# Outbound request timeout in seconds
SCRAPER_TIMEOUT=20

# --- Flask ---
FLASK_DEBUG=true
